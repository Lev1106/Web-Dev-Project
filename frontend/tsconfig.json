{
  "compileOnSave": false,
  "compilerOptions": {
    "baseUrl": "./",
    "downlevelIteration": true,
    "experimentalDecorators": true,
    "module": "ES2020",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2020",
    "typeRoots": [
      "node_modules/@types"
    ],
    "lib": [
      "ES2020",
      "DOM"
    ],
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "strict": true,
    "forceConsistentCasingInFileNames": true
  }
}
